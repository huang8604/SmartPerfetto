# ===================
# Environment variables (API keys, secrets)
# ===================
.env
.env.local
.env.*.local
*.env

# ===================
# Dependencies
# ===================
node_modules/
*/node_modules/

# ===================
# Build outputs
# ===================
dist/
build/
*/dist/
*/build/

# Perfetto build output (3.9GB, can rebuild with ./ui/run-dev-server)
perfetto/out/

# ===================
# Runtime data
# ===================
# SQLite WAL files (runtime, regenerated automatically)
*.db-shm
*.db-wal

# Uploaded trace files (user data, not needed in repo)
backend/uploads/*
!backend/uploads/.gitkeep

# ===================
# Logs
# ===================
logs/
backend/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ===================
# OS files
# ===================
.DS_Store
Thumbs.db

# ===================
# IDE files
# ===================
.vscode/
.idea/
*.swp
*.swo
*~

# ===================
# Misc
# ===================
# Runtime data
pids/
*.pid
*.seed
*.pid.lock

# Coverage
coverage/
*.lcov
.nyc_output

# Cache
.cache
.parcel-cache
.npm
.eslintcache

# Temporary
tmp/
temp/

# Git worktrees
.worktrees/

# ===================
# Claude Code
# ===================
# Local settings (project-specific, not shared)
.claude/settings.local.json
# But track settings.json for shared plugin/marketplace config

# ===================
# Agent runtime data (generated at runtime)
# ===================
backend/agent-checkpoints/
backend/agent-sessions/
backend/agent-state/
backend/agent-traces/

# ===================
# Test outputs (generated by test scripts)
# ===================
backend/test-output/

# ===================
# Playwright MCP (screenshots, recordings)
# ===================
.playwright-mcp/

# ===================
# Feature development notes (personal)
# ===================
Feature-Dev/
