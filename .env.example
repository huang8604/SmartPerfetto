# SmartPerfetto root env example (Docker Hub)
# Copy to .env for docker-compose.hub.yml:
#   cp .env.example .env
#
# Local source users usually want backend/.env instead:
#   cp backend/.env.example backend/.env
#
# If local `claude` already works in the same terminal, no AI env is needed for
# source runs. Docker cannot see host Claude Code auth, so Docker needs one
# explicit provider block below. Keep unused credential lines commented.

# ---------------------------------------------------
# Server
# ---------------------------------------------------
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:10000

# API Authentication (recommended in any shared environment)
# SMARTPERFETTO_API_KEY=replace_with_a_strong_random_secret

# ---------------------------------------------------
# AI runtime
# ---------------------------------------------------
# Default runtime is agentv3 (Claude Agent SDK) when AI_SERVICE is unset.
# Set AI_SERVICE=deepseek only for the deprecated agentv2 fallback.
# AI_SERVICE=claude-code

# Option 1: Anthropic direct
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# CLAUDE_MODEL=claude-sonnet-4-6
# CLAUDE_LIGHT_MODEL=claude-haiku-4-5

# Option 2: Claude Code-compatible third-party provider
# Uncomment ONE provider block. Base URLs are prefilled; replace only the key.
# SmartPerfetto uses CLAUDE_MODEL / CLAUDE_LIGHT_MODEL, not ANTHROPIC_MODEL.

# DeepSeek
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic
# ANTHROPIC_AUTH_TOKEN=your_deepseek_api_key_here
# CLAUDE_MODEL=deepseek-v4-pro
# CLAUDE_LIGHT_MODEL=deepseek-v4-flash

# GLM / Z.ai
# ANTHROPIC_BASE_URL=https://open.bigmodel.cn/api/anthropic
# ANTHROPIC_API_KEY=your_zhipuai_api_key_here
# CLAUDE_MODEL=glm-5.1
# CLAUDE_LIGHT_MODEL=glm-4.7-flash

# Qwen / Alibaba Cloud Bailian pay-as-you-go
# ANTHROPIC_BASE_URL=https://dashscope.aliyuncs.com/apps/anthropic
# ANTHROPIC_API_KEY=your_dashscope_api_key_here
# CLAUDE_MODEL=qwen3.6-plus
# CLAUDE_LIGHT_MODEL=qwen3.6-flash

# Qwen Coding Plan (sk-sp-* keys)
# ANTHROPIC_BASE_URL=https://coding.dashscope.aliyuncs.com/apps/anthropic
# ANTHROPIC_AUTH_TOKEN=your_bailian_coding_plan_api_key_here
# CLAUDE_MODEL=qwen3.6-plus
# CLAUDE_LIGHT_MODEL=qwen3.6-flash

# Kimi Code membership / Moonshot AI
# ANTHROPIC_BASE_URL=https://api.kimi.com/coding/
# ANTHROPIC_API_KEY=your_kimi_code_api_key_here
# CLAUDE_MODEL=kimi-for-coding
# CLAUDE_LIGHT_MODEL=kimi-for-coding

# Kimi / Moonshot platform
# ANTHROPIC_BASE_URL=https://api.moonshot.cn/anthropic
# ANTHROPIC_AUTH_TOKEN=your_moonshot_api_key_here
# CLAUDE_MODEL=kimi-k2.6
# CLAUDE_LIGHT_MODEL=kimi-k2.5

# Doubao / Volcano Ark Coding Plan
# ANTHROPIC_BASE_URL=https://ark.cn-beijing.volces.com/api/coding
# ANTHROPIC_AUTH_TOKEN=your_volcengine_ark_api_key_here
# CLAUDE_MODEL=doubao-seed-2.0-code
# CLAUDE_LIGHT_MODEL=doubao-seed-2.0-code

# MiniMax (China). Global: https://api.minimax.io/anthropic
# ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
# ANTHROPIC_AUTH_TOKEN=your_minimax_api_key_here
# CLAUDE_MODEL=MiniMax-M2.7
# CLAUDE_LIGHT_MODEL=MiniMax-M2.7-highspeed

# Tencent Hunyuan
# ANTHROPIC_BASE_URL=https://api.hunyuan.cloud.tencent.com/anthropic
# ANTHROPIC_AUTH_TOKEN=your_tencent_hunyuan_api_key_here
# CLAUDE_MODEL=hunyuan-2.0-thinking-20251109
# CLAUDE_LIGHT_MODEL=hunyuan-2.0-instruct-20251111

# Baidu Qianfan
# ANTHROPIC_BASE_URL=https://qianfan.baidubce.com/anthropic
# ANTHROPIC_AUTH_TOKEN=your_qianfan_api_key_here
# CLAUDE_MODEL=deepseek-v3.2
# CLAUDE_LIGHT_MODEL=deepseek-v3.2

# StepFun Step Plan
# ANTHROPIC_BASE_URL=https://api.stepfun.com/step_plan
# ANTHROPIC_AUTH_TOKEN=your_stepfun_api_key_here
# CLAUDE_MODEL=step-3.5-flash-2603
# CLAUDE_LIGHT_MODEL=step-3.5-flash

# SiliconFlow
# ANTHROPIC_BASE_URL=https://api.siliconflow.com/
# ANTHROPIC_API_KEY=your_siliconflow_api_key_here
# CLAUDE_MODEL=Qwen/Qwen3-235B-A22B-Thinking-2507
# CLAUDE_LIGHT_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

# Huawei Cloud ModelArts MaaS (China). Intl AP-Singapore:
# https://api-ap-southeast-1.modelarts-maas.com/anthropic
# ANTHROPIC_BASE_URL=https://api.modelarts-maas.com/anthropic
# ANTHROPIC_AUTH_TOKEN=your_huawei_maas_api_key_here
# CLAUDE_MODEL=deepseek-v3.2
# CLAUDE_LIGHT_MODEL=qwen3-32b

# Option 3: Custom one-api / new-api / LiteLLM gateway
# ANTHROPIC_BASE_URL=http://localhost:3000
# ANTHROPIC_AUTH_TOKEN=sk-proxy-xxx
# CLAUDE_MODEL=your-proxy-main-model
# CLAUDE_LIGHT_MODEL=your-proxy-light-model

# Model & Agent Tuning (optional)
# CLAUDE_MAX_TURNS=60
# CLAUDE_QUICK_MAX_TURNS=10
# CLAUDE_FULL_PER_TURN_MS=60000
# CLAUDE_QUICK_PER_TURN_MS=40000
# CLAUDE_VERIFIER_TIMEOUT_MS=60000
# CLAUDE_CLASSIFIER_TIMEOUT_MS=30000
# SMARTPERFETTO_OUTPUT_LANGUAGE=zh-CN

# ---------------------------------------------------
# Deprecated agentv2 fallback (legacy only)
# ---------------------------------------------------
# AI_SERVICE=deepseek
# DEEPSEEK_API_KEY=your_deepseek_api_key_here
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_REASONING_MODEL=deepseek-v4-pro

# ---------------------------------------------------
# File Upload
# ---------------------------------------------------
MAX_FILE_SIZE=2147483648
UPLOAD_DIR=./uploads

# Perfetto Configuration (optional - uses default paths if not set)
# TRACE_PROCESSOR_PATH=/path/to/trace_processor_shell
# PERFETTO_PATH=/path/to/perfetto

# Agent feature flags
FEATURE_AGENT_SCENE_RECONSTRUCT=true
FEATURE_AGENT_LOGS_API=true

# ADB full-mode guard (default false). Requires this flag AND per-request allowAgentFullMode=true.
SMARTPERFETTO_ALLOW_AGENT_ADB_FULL_MODE=false
