# ANTHROPIC_AUTH_TOKEN=your_stepfun_api_key_here
# CLAUDE_MODEL=step-3.5-flash-2603
# CLAUDE_LIGHT_MODEL=step-3.5-flash

# ---------------------------------------------------
# SiliconFlow (硅基流动)
# ---------------------------------------------------
# Console: https://cloud.siliconflow.com/
# Claude Code-compatible Base URL:
# ANTHROPIC_BASE_URL=https://api.siliconflow.com/
# ANTHROPIC_API_KEY=your_siliconflow_api_key_here
